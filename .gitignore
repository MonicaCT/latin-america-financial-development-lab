# Legacy folders from the original scripts stay out of Git unless explicitly curated.
/Data/
/Data.ES/
/Final_*/

# Reopen the lowercase project data directory on case-insensitive Windows Git.
!/data/
!/data/processed/
!/data/processed/*.csv
!/data/processed/*.md
!/data/metadata/
!/data/metadata/*.csv
!/data/metadata/*.md

# Keep large or sensitive raw files out of Git by default, but keep WDI raw JSON/CSV.
/data/raw/*
!/data/raw/
!/data/raw/README.md
!/data/raw/world_bank_wdi/
!/data/raw/world_bank_wdi/*.json
!/data/raw/world_bank_wdi/*.csv

*.xlsx
*.xls
*.zip
*.rds
*.RDS
*.RData

# Publication exports generated by the project are intentionally versionable.
!outputs/tables/excel/*.xlsx

dashboard/rsconnect/
